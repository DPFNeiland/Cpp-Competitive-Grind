{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Only C++",
            "type": "shell",
            "command": "\"${fileDirname}\\${fileBasenameNoExtension}.exe\""
        },
        {
            "label": "Build C++",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",
                "-O2",
                "-Wall",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build"
        },
        {
            "label": "Run C++",
            "type": "shell",
            "command": "\"${fileDirname}\\${fileBasenameNoExtension}.exe\"",
            "dependsOn": "Build C++",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}